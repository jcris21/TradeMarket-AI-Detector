# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# If unset/empty, the built-in market simulator is used.
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (testing).
LLM_MOCK=false

# Optional: VIX regime gate threshold (float, default 25.0).
# When the latest ^VIX close exceeds this value, all BUY signals are
# converted to AVOID for the run. Set to 999 to disable the gate entirely.
ANALYSIS_VIX_THRESHOLD=25.0
